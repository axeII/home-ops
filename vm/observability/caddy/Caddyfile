# Caddy reverse proxy for observability stack
# IP-allowlisted to home LAN

grafana.internal, grafana.juno.moe {
    tls internal

    @allowed {
        remote_ip 192.168.69.0/24 192.168.88.0/24
    }

    handle @allowed {
        reverse_proxy grafana:3000
    }

    handle {
        abort
    }
}

:80 {
    @allowed {
        remote_ip 192.168.69.0/24 192.168.88.0/24
    }

    handle @allowed {
        @metrics host metrics.internal
        handle @metrics {
            reverse_proxy prometheus:9090
        }

        @logs host logs.internal
        handle @logs {
            reverse_proxy loki:3100
        }

        @grafana host grafana.internal grafana.juno.moe
        redir @grafana https://{host}{uri}
    }

    handle {
        abort
    }
}
